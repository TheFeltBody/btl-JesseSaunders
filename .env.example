# Copy this file to ".env" (locally) and set the same vars in Cloudflare Pages.
# Get the first two from Supabase: Dashboard → Project Settings → API.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Comma-separated list of the only emails allowed to sign in.
# Leave blank to allow any email that successfully signs in.
VITE_ALLOWED_EMAILS=you@example.com,partner@example.com
